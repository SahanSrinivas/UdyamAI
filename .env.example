# Google Generative AI key — either name works.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_key_here
# GEMINI_API_KEY=your_gemini_key_here

# AWS RDS Postgres — optional. When set, dashboard queries real AgamiAI
# datasets from Postgres; otherwise falls back to bundled samples.
# DATABASE_URL=postgres://user:pass@your-rds.rds.amazonaws.com:5432/udyamai
